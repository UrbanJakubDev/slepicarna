// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EggCollection {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  count      Int      @default(0)
  userId     String? // Pro budoucí multi-user, zatím volitelné

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("slepicarna_egg_collection")
}

model Transaction {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  type        String // "SALE" | "FEED" | "EXPENSE"
  amount      Float // v Kč
  quantity    Int? // Počet vajec nebo kg krmiva
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("slepicarna_transaction")
}

model EggWithdrawal {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  boxCount   Int // Počet krabiček (násobky 10)
  totalEggs  Int // Celkový počet vajec (boxCount * 10)
  name       String? // Kdo si vzal
  thanks     String   @default("Děkuji")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("slepicarna_egg_withdrawal")
}

model FlockHistory {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  count     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("slepicarna_flock_history")
}
